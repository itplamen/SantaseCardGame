@inject GameState GameState;
@inject TrickState TrickState;

@if (Deck.Cards.Any())
{
    <CardComponent Card="Deck.TrumpCard" IsTrumpCard="true"></CardComponent>
    <div id="DeckCards" class="card-component" @onclick="GameState.CloseDeck">
        <div id="DeckCardsCount">@(Deck.Cards.Count)</div>
        <img src="/images/cards/Back.png" id="DeckBackCard" alt="DeckBackCard" class="card-component" />
    </div>
}

@code {
    [Parameter]
    public Deck Deck { get; set; }
}
@inject ITrickState TrickState;

@if (cards != null)
{
    @if (cards[0] != null)
    {
        <img src="/images/cards/@string.Concat(cards[0].Name,".png")" class="first-player-trick-card" />
    }

    @if (cards[1] != null)
    {
        <img src="/images/cards/@string.Concat(cards[1].Name,".png")" class="second-player-trick-card" />
    }
}

@code {
    private Card[] cards;

    protected override void OnInitialized()
    {
        TrickState.OnDisplay += Display;
        TrickState.OnClear += Clear;
    }

    private void Display()
    {
        cards = TrickState.Cards;

        StateHasChanged();
    }

    private void Clear()
    {
        cards = null;

        StateHasChanged();
    }
}

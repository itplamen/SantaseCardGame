<img id="@PlayerAction.Card.Name"
     alt="@PlayerAction.Card.Name" 
     @onclick="@(() => OnClick.InvokeAsync(PlayerAction))"
     src="/images/cards/@string.Concat(PlayerAction.Card.Name,".png")"
     class="card-component @(PlayerAction.Type == PlayerActionType.ChangeTrump ? "trump-card" : string.Empty)" />

@code {
    [Parameter]
    public PlayerAction PlayerAction { get; set; } 

    [Parameter]
    public EventCallback<PlayerAction> OnClick { get; set; }
}
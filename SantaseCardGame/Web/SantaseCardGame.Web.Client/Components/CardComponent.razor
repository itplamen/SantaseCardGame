@inject IJSRuntime JsRuntime;
@inject TrickState TrickState;

<img src="/images/cards/@string.Concat(Card.Name,".png")"
     id="@Card.Name"
     alt="@Card.Name" 
     @onclick="Play"
     class="card-component @(IsTrumpCard ? "trump-card" : string.Empty)" />

@code {
    [Parameter]
    public Card Card { get; set; }

    [Parameter]
    public bool IsTrumpCard { get; set; }

    private async Task Play()
    {
        TrickState.AddCard(Card);

        await JsRuntime.InvokeVoidAsync("playCard", Card.Name);
    }
}

<img src="/images/cards/@string.Concat(Card.Name,".png")"
     id="@Card.Name"
     alt="@Card.Name" 
     @onclick="@(() => OnClick.InvokeAsync(Card))"
     class="card-component @(IsTrumpCard ? "trump-card" : string.Empty)" />

@code {
    [Parameter]
    public Card Card { get; set; }

    [Parameter]
    public bool IsTrumpCard { get; set; }    

    [Parameter]
    public EventCallback<Card> OnClick { get; set; }
}

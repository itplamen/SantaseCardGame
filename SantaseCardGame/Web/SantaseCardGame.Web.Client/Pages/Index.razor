@page "/"

@inject TrickState TrickState;
@inject ITrickWinner TrickWinner;
@inject IGameManager GameManager;

@if (Game != null)
{
    <PlayerComponent Player="Game.FirstPlayer"></PlayerComponent>
    <DeckComponent Deck="Game.Deck"></DeckComponent>
    <TrickComponent></TrickComponent>
    <PlayerComponent Player="Game.SecondPlayer"></PlayerComponent>
}

@code {

    public Game Game { get; set; }

    protected override void OnInitialized()
    {
        Game = GameManager.StartGame("Plamen");

        TrickState.OnPlayTrick += () => PlayTrick();
        TrickState.FirstToPlay = PlayerPosition.First;
    }

    private async void PlayTrick()
    {
        List<Card> trickCards = new List<Card>()
        {
            TrickState.FirstPlayedCard,
            TrickState.SecondPlayedCard
        };

        Hand hand = new Hand() { Cards = trickCards };
        PlayerPosition winnerPosition = TrickWinner.GetWinner(trickCards, Game.Deck.TrumpCard.Suit);

        if (winnerPosition == PlayerPosition.First)
        {
            Game.FirstPlayer.Hands.Add(hand);
        }
        else
        {
            Game.SecondPlayer.Hands.Add(hand);
        }

        await Task.Delay(1500);

        TrickState.Clear();
        TrickState.FirstToPlay = winnerPosition;



    }
}
@page "/"

@inject IJSRuntime JSRuntime;
@inject ITrickState TrickState;
@inject IGameEngine GameEngine;

@if (Game != null)
{
    <PlayerComponent Player="Game.FirstPlayer"></PlayerComponent>
    <DeckComponent Deck="Game.Deck"></DeckComponent>
    <TrickComponent></TrickComponent>
    <PlayerComponent Player="Game.SecondPlayer"></PlayerComponent>
    <div id="Announce"></div>
}

@code {

    public Game Game { get; set; }

    protected override void OnInitialized()
    {
        Game = GameEngine.StartGame("Plamen");
        TrickState.OnNotify += Notify;

        TrickState.OnPlay += PlayTrick;
        TrickState.PlayerTurn = PlayerPosition.First;
        TrickState.TrumpCardSuit = Game.Deck.TrumpCard.Suit;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await Task.Delay(1500);

            GameEngine.AIPlay(Game.FirstPlayer);
        }

        StateHasChanged();
    }

    private void PlayTrick()
    {
        GameEngine.PlayTrick(Game);
    }

    private void Notify(string message)
    {
        JSRuntime.InvokeVoidAsync("announce", message);
    }
}